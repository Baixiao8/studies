# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/

# Python 虚拟环境(本地构建工具,不进仓库)
# 带斜杠匹配目录,不带斜杠匹配符号链接(可指向跨项目共享 venv)
tools/.venv/
tools/.venv
.venv/
.venv

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts (intermediate, not the final index.html)
reports/*/build/
reports/*/dist/
reports/*/_temp/

# ─── A 模式 CI · 部署产物(由 GitHub Actions 在 gh-pages 分支生成,不进 main)───
# main 分支只存源:chapters/ + parts/ + assets/ + _shared/(脚本+样式)
# 以下产物全部 .gitignored,由 CI 自动生成 + 推到 gh-pages
reports/*/index.html
reports/*/*.epub
.deploy/
# 顶层 index.html 仍 commit(首页本体,非生成物)

# ─── B 模式 · 单文件 SPA 报告例外(不走 build.py,index.html 是源不是产物)───
# 这些报告没有 chapters/+parts/ 结构,index.html 就是本体,必须 commit
# CI 会对没有 chapters/ 的报告走"整目录 mirror"分支(见 workflow)
!reports/2026-05-marathon/index.html
!reports/2026-05-skills-building-guide/index.html
!reports/2026-05-thinking-evolution/index.html
!reports/2026-05-mailchimp-voice-tone/index.html

# Local config (不要把本地密钥提交)
.env
.env.local
*.key
config.local.*

# Claude Code 本地配置和缓存(可能含 API 配置/权限设置,不公开)
.claude/

# 旧版本归档 · 强烈建议排除(含个人训练数据 + COROS MCP 工具 + 旧版报告)
_legacy/

# 旧版本:之前用过的 index.embed.html(现在 build 默认就是 inline,index.html 即自包含版)
reports/*/index.embed.html
reports/*/index.v1.html

# Local 本地 HTTP 服务器日志
/tmp/http_server.log
